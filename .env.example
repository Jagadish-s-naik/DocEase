# Environment Variables for DocEase - AI Document Simplifier

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# AUTHENTICATION
# ============================================
# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT Secret for session encryption
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Stripe Product/Price IDs
STRIPE_PRICE_ID_MONTHLY=price_monthly_subscription_id

# ============================================
# AI / LLM CONFIGURATION
# ============================================
# OpenAI API (or any LLM provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000

# Alternative: Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_key
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Alternative: Google Gemini
# GOOGLE_AI_API_KEY=your_google_ai_key
# GOOGLE_AI_MODEL=gemini-pro

# ============================================
# OCR CONFIGURATION
# ============================================
# Cloud OCR Provider (optional)
# GOOGLE_CLOUD_PROJECT_ID=your_project_id
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ============================================
# TRANSLATION API (Optional Enhancement)
# ============================================
# GOOGLE_TRANSLATE_API_KEY=your_translation_key

# ============================================
# SECURITY & ENCRYPTION
# ============================================
# AES-256 encryption key for document encryption
ENCRYPTION_KEY=your_32_byte_encryption_key_here
ENCRYPTION_IV=your_16_byte_iv_here

# ============================================
# RATE LIMITING & QUOTAS
# ============================================
# Free tier limits
FREE_TIER_DOCUMENT_LIMIT=3
PAID_TIER_DOCUMENT_LIMIT=999999

# Rate limit per IP (requests per minute)
RATE_LIMIT_PER_MINUTE=20

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE_MB=10
MAX_PAGES_PER_DOCUMENT=50
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# ============================================
# MONITORING & LOGGING
# ============================================
# Sentry for error tracking (optional)
# SENTRY_DSN=your_sentry_dsn

# LogRocket (optional)
# LOGROCKET_APP_ID=your_logrocket_id

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# SendGrid or similar for email notifications
# SENDGRID_API_KEY=your_sendgrid_key
# EMAIL_FROM=noreply@docease.com

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Admin email addresses (comma-separated)
ADMIN_EMAILS=admin@docease.com

# ============================================
# DEPLOYMENT
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_GUEST_MODE=true
ENABLE_AUTO_DELETE=true
ENABLE_ANALYTICS=true
ENABLE_MALWARE_SCAN=false
